# Supabase (required — this IS your backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_DEFAULT_GRADUATE_ID=noura-2026

# AI (optional — disable on free static hosting unless you deploy functions)
VITE_AI_API_BASE=/api
VITE_AI_ENABLED=false

# Setup: run supabase/schema.sql in Supabase Dashboard → SQL Editor
# Deploy: push to GitHub → connect Vercel or Netlify → add env vars above
